# ── Core ──────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
DAWN_API_KEY=dev-key

# ── Control Center Supabase (separate project for jarvis_* tables) ────────────
# CC_SUPABASE_URL=https://matqyguixfgsymmdlzms.supabase.co
# CC_SUPABASE_SERVICE_KEY=your-cc-service-role-key

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_MODE=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Local Model (optional) ────────────────────────────────────────────────────
# LOCAL_MODEL_PATH=/path/to/model.gguf
# LOCAL_MODEL_N_CTX=4096
# LOCAL_MODEL_N_THREADS=4

# ── Tools ─────────────────────────────────────────────────────────────────────
FILESYSTEM_SANDBOX_ROOT=./sandbox
SKILLS_INSTALL_ROOT=./installed_skills
TOOLS_ENABLED=filesystem,git,websearch,install_skill,terminal,web_fetch,ssh,nmap,osint,mcp

# ── Web Search ────────────────────────────────────────────────────────────────
# BRAVE_SEARCH_API_KEY=your-brave-key

# ── OSINT ─────────────────────────────────────────────────────────────────────
# SHODAN_API_KEY=your-shodan-key

# ── Auth Tiers ────────────────────────────────────────────────────────────────
# DAWN_API_KEYS={"sk-owner-xxx":"owner","sk-app-yyy":"service"}

# ── OCR ───────────────────────────────────────────────────────────────────────
# TESSERACT_CMD=/usr/bin/tesseract

# ── Slack ─────────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
# SLACK_SIGNING_SECRET=your-signing-secret
# AGENT_CHANNEL_LEADS=sales
# AGENT_CHANNEL_PIPELINE=sales
# AGENT_CHANNEL_CAMPAIGNS=marketing
# AGENT_CHANNEL_REVENUE=general
# AGENT_CHANNEL_SYSTEM=ops
# AGENT_CHANNEL_ALERTS=ops

# ── CRM (Regent Growth Engine) ────────────────────────────────────────────────
# CRM_FUNCTIONS_BASE=https://your-project.functions.supabase.co
# CRM_AGENT_API_KEY=your-crm-agent-key

# ── Forge CMS ─────────────────────────────────────────────────────────────────
# FORGE_API_URL=https://forge.regent.ug
# FORGE_API_KEY=your-forge-api-key

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=dawn@regent.ug
# SMTP_PASSWORD=your-smtp-app-password
# SMTP_FROM_EMAIL=dawn@regent.ug

# ── Axis ERP ──────────────────────────────────────────────────────────────────
# AXIS_API_URL=https://axis.regent.ug
# AXIS_API_KEY=your-axis-api-key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
