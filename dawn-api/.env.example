# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# LLM Mode: "deepseek" until local model is ready, then switch to "local"
LLM_MODE=deepseek

# DeepSeek API (active while local model isn't ready)
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Local LLM — fill in once you have the .gguf file
# LOCAL_MODEL_PATH=/models/qwen2.5-3b-instruct-q4_k_m.gguf
# LOCAL_MODEL_N_CTX=4096
# LOCAL_MODEL_N_THREADS=4

# Simple API key to protect the DAWN API
DAWN_API_KEY=change-this-to-something-secure

# CORS — your Vercel URL + localhost for dev
ALLOWED_ORIGINS=http://localhost:3000,https://dawn.regentplatform.com
